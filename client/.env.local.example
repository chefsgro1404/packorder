# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit it.
#
# In Azure SWA production, set these as Application Settings in the Azure portal or CLI — not in a file.

# URL of the Azure Functions app running locally
AZURE_FUNCTIONS_URL=http://localhost:7071

# Must match InternalApiSecret in functions/local.settings.json
INTERNAL_API_SECRET=REPLACE_must_match_InternalApiSecret_in_local_settings_json

# Display name shown in the app
NEXT_PUBLIC_APP_NAME=ShipScan
